PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/securefiles
JWT_SECRET=my_super_secret_key_123
JWT_ACCESS_SECRET=replace_with_a_strong_random_value
JWT_REFRESH_SECRET=replace_with_a_strong_random_value
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
ENCRYPTION_KEY=base64:... (32 bytes for AES-256, base64 encoded)
ENCRYPTION_IV_SECRET=base64:... (12 bytes recommended for GCM, base64)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
CORS_ORIGIN=https://your-frontend-domain.com 